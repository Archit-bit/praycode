#!/usr/bin/env bash
set -euo pipefail

SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  SOURCE_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$SOURCE_DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
ROOT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

usage() {
  cat <<'EOF'
Usage:
  praycode           Start PrayCode
  praycode start     Start PrayCode
  praycode status    Show service status
  praycode stop      Stop PrayCode
  praycode restart   Restart PrayCode

Open after start:
  http://127.0.0.1:5173
EOF
}

command="${1:-start}"

case "$command" in
  start)
    exec "$ROOT_DIR/scripts/start_praycode.sh"
    ;;
  status)
    exec "$ROOT_DIR/scripts/status_praycode.sh"
    ;;
  stop)
    exec "$ROOT_DIR/scripts/stop_praycode.sh"
    ;;
  restart)
    "$ROOT_DIR/scripts/stop_praycode.sh" || true
    exec "$ROOT_DIR/scripts/start_praycode.sh"
    ;;
  help|-h|--help)
    usage
    ;;
  *)
    echo "Unknown command: $command" >&2
    echo >&2
    usage >&2
    exit 1
    ;;
esac
